{
  "name": "terminal-stress",
  "description": "Boot-time POSIX TTY, scheduler sleep, signal, and ncurses compatibility stress suite",
  "exec": "/usr/bin/terminal-stress",
  "args": [],
  "type": "oneshot",
  "terminal": "/dev/pts/boot-terminal",
  "autostart": @RADIX_TERMINAL_STRESS_AUTOSTART@,
  "order": 60,
  "requires": ["storage-root", "base-terminal"],
  "after": ["base-terminal"],
  "restart": "no",
  "stdout": "/var/log/radix/terminal-stress.log",
  "stderr": "/var/log/radix/terminal-stress.log"
}
